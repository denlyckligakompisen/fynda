rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Regler för användarspecifika favoriter (users-samlingen)
    // Tillåt endast inloggade användare att läsa/skriva sina egna dokument
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // 2. Regler för PDF-analyser (analyses-samlingen)
    match /analyses/{analysisId} {
      // Tillåt endast läsning och skrivning för autentiserad administratör
      allow read, write: if request.auth != null
        && request.auth.token.email == 'frebrandberg@gmail.com'
        && request.auth.token.email_verified == true;
    }

    // 3. Default-deny för alla andra/framtida samlingar
    // Firestore nekar redan som standard om ingen regel matchar, men detta
    // gör det uttryckligt så att nya samlingar inte råkar bli öppna via
    // konsolen utan att gå via denna fil.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
