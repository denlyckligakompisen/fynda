rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Regler för användarspecifika favoriter (users-samlingen)
    // Tillåt endast inloggade användare att läsa/skriva sina egna dokument
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // 2. Regler för PDF-analyser (analyses-samlingen)
    match /analyses/{analysisId} {
      // Tillåt alla att läsa sparade analyser
      allow read: if true; 
      
      // Tillåt endast skrivning (skapa/uppdatera/radera) om användaren är autentiserad med din administratörs-epost
      allow write: if request.auth != null && request.auth.token.email == 'frebrandberg@gmail.com' && request.auth.token.email_verified == true;
    }
  }
}
